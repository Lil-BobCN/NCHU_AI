# NCHU AI Assistant - 根目录环境变量
# 复制此文件为 .env 并填入你的配置
# cp .env.example .env

# ========== 通义千问 API ==========
# 从阿里云 DashScope 获取: https://dashscope.console.aliyun.com/
QWEN_API_KEY=your-qwen-api-key-here
QWEN_MODEL=qwen3.5-plus

# ========== 服务器 ==========
HOST=0.0.0.0
PORT=5000
DEBUG=false

# ========== Redis ==========
# Docker 环境下使用容器名 "redis"，本地开发使用 "localhost"
REDIS_HOST=redis
REDIS_PORT=6379

# ========== Session ==========
# 生产环境请使用强随机字符串
SESSION_SECRET_KEY=change-this-to-a-random-string

# ========== 管理员 ==========
# 管理员用户名列表（逗号分隔）
ADMIN_USERS=admin

# ========== CORS ==========
# 允许的来源（逗号分隔），"null" 用于支持 file:// 协议
CORS_ORIGINS=http://localhost,null
