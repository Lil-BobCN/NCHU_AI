# NCHU AI Counselor - FastAPI Phase 1 environment
# Copy to .env for local development:
#   cp .env.example .env
#
# Host defaults below are chosen for commands run from the host after:
#   docker compose -f docker-compose.phase1.yml up -d
# The compose file overrides service URLs for the api container.

# Application
APP_NAME=NCHU AI Counselor API
APP_VERSION=2.0.0
HOST=0.0.0.0
PORT=8000
API_BIND_HOST=127.0.0.1
API_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=counselor
POSTGRES_PASSWORD=counselor_pass
POSTGRES_DB=counselor_db
DATABASE_URL=postgresql+asyncpg://counselor:counselor_pass@localhost:5432/counselor_db

# Redis
REDIS_BIND_HOST=127.0.0.1
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/1

# Qwen / DashScope real-model proxy (Phase 3R)
# Uses the existing Qwen/DashScope configuration family; do not put these in frontend env.
DASHSCOPE_API_KEY=
DASHSCOPE_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
ENABLE_THINKING=false
CHAT_MODEL_TIMEOUT_SECONDS=60
CHAT_MODEL_SYSTEM_PROMPT=你是南昌航空大学 AI 辅导员 Demo 的学生端助手。请用中文给出清晰、克制、可执行的支持建议；不要声称已经接入真实学校数据库、RAG 知识库或真实学生档案。遇到自伤、他伤或紧急危机风险时，优先建议立即联系紧急服务、校内值班老师或心理咨询中心。

# MinIO object/original document storage
MINIO_BIND_HOST=127.0.0.1
MINIO_ENDPOINT=localhost:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=nchu-counselor-documents
MINIO_SECURE=false

# Milvus vector database
MILVUS_BIND_HOST=127.0.0.1
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091
MILVUS_DB_NAME=default
MILVUS_COLLECTION=nchu_counselor_documents
MILVUS_VECTOR_DIM=1024
MILVUS_METRIC_TYPE=COSINE
MILVUS_INDEX_TYPE=IVF_FLAT
MILVUS_INDEX_NLIST=1024
MILVUS_TOKEN=

# Optional Docker image overrides for restricted registry networks.
# Leave empty to use compose defaults, which avoid Docker Hub for MinIO/Milvus.
# MILVUS_IMAGE=docker.m.daocloud.io/milvusdb/milvus:v2.6.15
# MINIO_IMAGE=quay.io/minio/minio:RELEASE.2024-12-18T13-15-44Z
# MILVUS_MINIO_IMAGE=quay.io/minio/minio:RELEASE.2024-12-18T13-15-44Z

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000,http://localhost:80,http://localhost

# Security note:
# Published Docker ports bind to 127.0.0.1 by default for local validation.
# For trusted private-network access, set *_BIND_HOST to the required internal
# interface and replace default PostgreSQL/MinIO credentials before starting.
