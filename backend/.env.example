# NCHU AI Counselor - 后端环境变量
# 复制此文件为 .env 并填入你的配置
# cp .env.example .env

# ========== Application ==========
APP_NAME=NCHU AI Counselor API
APP_VERSION=2.0.0
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ========== DashScope (通义千问) ==========
# 从阿里云 DashScope 获取: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your-dashscope-api-key-here
DASHSCOPE_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.5-plus
EMBEDDING_MODEL=text-embedding-v3
ENABLE_THINKING=false

# ========== Database (PostgreSQL) ==========
# Docker 环境下使用容器名 "postgres"，本地开发使用 "localhost"
DATABASE_URL=postgresql+asyncpg://counselor:counselor_pass@postgres:5432/counselor_db
POSTGRES_USER=counselor
POSTGRES_PASSWORD=counselor_pass
POSTGRES_DB=counselor_db

# ========== Vector Store (Qdrant) ==========
# Docker 环境下使用容器名 "qdrant"，本地开发使用 "localhost"
QDRANT_HOST=qdrant
QDRANT_URL=http://qdrant:6333

# ========== Redis ==========
# Docker 环境下使用容器名 "redis"，本地开发使用 "localhost"
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/1

# ========== CORS ==========
# 允许的来源（逗号分隔），"null" 用于支持 file:// 协议
CORS_ORIGINS=http://localhost,null

# ========== JWT ==========
# 生产环境请使用强随机字符串
JWT_SECRET_KEY=change-this-to-a-random-string
