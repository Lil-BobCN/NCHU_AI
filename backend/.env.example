# NCHU AI Counselor - FastAPI Phase 1 environment
# Copy to .env for local development:
#   cp .env.example .env
#
# Host defaults below are chosen for commands run from the host after:
#   docker compose -f docker-compose.phase1.yml up -d
# The compose file overrides service URLs for the api container.

# Application
APP_NAME=NCHU AI Counselor API
APP_VERSION=2.0.0
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# DashScope / model integration
# Phase 1 smoke does not call DashScope; keep a placeholder until model work begins.
DASHSCOPE_API_KEY=
DASHSCOPE_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.5-plus
EMBEDDING_MODEL=text-embedding-v3
ENABLE_THINKING=false

# PostgreSQL
POSTGRES_USER=counselor
POSTGRES_PASSWORD=counselor_pass
POSTGRES_DB=counselor_db
DATABASE_URL=postgresql+asyncpg://counselor:counselor_pass@localhost:5432/counselor_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/1

# MinIO object/original document storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=nchu-counselor-documents
MINIO_SECURE=false

# Milvus vector database
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DB_NAME=default
MILVUS_COLLECTION=nchu_counselor_documents
MILVUS_VECTOR_DIM=1024
MILVUS_METRIC_TYPE=COSINE
MILVUS_INDEX_TYPE=IVF_FLAT
MILVUS_INDEX_NLIST=1024
MILVUS_TOKEN=

# Optional Docker image overrides for restricted registry networks.
# Leave empty to use compose defaults, which avoid Docker Hub for MinIO/Milvus.
# MILVUS_IMAGE=docker.m.daocloud.io/milvusdb/milvus:v2.6.15
# MINIO_IMAGE=quay.io/minio/minio:RELEASE.2024-12-18T13-15-44Z
# MILVUS_MINIO_IMAGE=quay.io/minio/minio:RELEASE.2024-12-18T13-15-44Z

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000,http://localhost:80,http://localhost,null

# JWT
JWT_SECRET_KEY=phase1-dev-jwt-secret-change-before-production
